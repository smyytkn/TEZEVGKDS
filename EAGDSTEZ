def fmt_tl(val: float) -> str:
    """1250000 → '1.250.000'"""
    return f"{int(val):,}".replace(",", ".")


def parse_tl(s: str) -> float:
    """'1.250.000' → 1250000.0"""
    try:
        return float(s.replace(".", "").replace(",", "."))
    except Exception:
        return 0.0


