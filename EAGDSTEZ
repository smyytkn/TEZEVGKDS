def oran_arac(n_toplam, oran):
    """n_toplam araçtan oran (0-1) kadarını tam sayıya yuvarla."""
    return int(round(n_toplam * oran))


def emisyon_hesapla(n_oto_dizel, n_oto_ev, n_mini_dizel, n_mini_ev,
                    km_oto, km_mini):
    """
    IPCC Tier 2 metodolojisiyle yıllık emisyon hesaplar.
    Her araç tipi için km'yi araç sayısıyla orantılı böler.
    """
    n_oto_total  = max(n_oto_dizel + n_oto_ev, 1)
    n_mini_total = max(n_mini_dizel + n_mini_ev, 1)

    oto_km_d  = (n_oto_dizel  / n_oto_total)  * km_oto
    oto_km_ev = (n_oto_ev     / n_oto_total)  * km_oto
    mini_km_d  = (n_mini_dizel / n_mini_total) * km_mini
    mini_km_ev = (n_mini_ev    / n_mini_total) * km_mini

    co2_oto_d  = oto_km_d  * TUK_OTOBÜS_DIZEL  * EF_CO2_DIZEL
    ch4_oto_d  = oto_km_d  * EF_CH4_OTOBÜS_DIZEL  / 1e6
    n2o_oto_d  = oto_km_d  * EF_N2O_OTOBÜS_DIZEL  / 1e6
    co2_oto_ev = oto_km_ev * (E_OTOBÜS_EV / ETA_SARJ) * EF_GRID

    co2_mini_d  = mini_km_d  * TUK_MINİBÜS_DIZEL  * EF_CO2_DIZEL
    ch4_mini_d  = mini_km_d  * EF_CH4_MINİBÜS_DIZEL / 1e6
    n2o_mini_d  = mini_km_d  * EF_N2O_MINİBÜS_DIZEL / 1e6
    co2_mini_ev = mini_km_ev * (E_MINİBÜS_EV / ETA_SARJ) * EF_GRID

    CO2_kg   = co2_oto_d + co2_oto_ev + co2_mini_d + co2_mini_ev
    CH4_kg   = ch4_oto_d + ch4_mini_d
    N2O_kg   = n2o_oto_d + n2o_mini_d
    CO2e_ton = (CO2_kg + CH4_kg * GWP_CH4 + N2O_kg * GWP_N2O) / 1000

    return {"CO2_kg": CO2_kg, "CH4_kg": CH4_kg, "N2O_kg": N2O_kg, "CO2e_ton": CO2e_ton}


def maliyet_serileri(n_oto_dizel, n_oto_ev, n_mini_dizel, n_mini_ev,
                     n_arac_ev_oto, n_arac_ev_mini,
                     fiyat_oto_ev, fiyat_mini_ev,
                     tufe, yil, odeme_plan):
    """
    Aylık maliyet serisini (yakıt + bakım + taksit) döndürür.
    EV aracına ait yatırım maliyeti, ödeme planına göre taksitlere bölünür.
    """
    n_oto_total  = max(n_oto_dizel + n_oto_ev, 1)
    n_mini_total = max(n_mini_dizel + n_mini_ev, 1)

    # Aylık yakıt (birinci yıl, enflasyonsuz)
    ayl_yakıt_d = (
        n_oto_dizel  * (km_otobüs_yillik  / n_oto_total)  * TUK_OTOBÜS_DIZEL  * dizel_fiyat +
        n_mini_dizel * (km_minibüs_yillik / n_mini_total) * TUK_MINİBÜS_DIZEL * dizel_fiyat
    ) / 12

    ayl_yakıt_ev = (
        n_oto_ev  * (km_otobüs_yillik  / n_oto_total)  * (E_OTOBÜS_EV  / ETA_SARJ) * elektrik_fiyat +
        n_mini_ev * (km_minibüs_yillik / n_mini_total) * (E_MINİBÜS_EV / ETA_SARJ) * elektrik_fiyat
    ) / 12

    # Aylık bakım (birinci yıl)
    ayl_bakım = (
        n_oto_dizel  * bakim_otobüs_dizel  +
        n_mini_dizel * bakim_minibüs_dizel +
        n_oto_ev     * bakim_otobüs_ev     +
        n_mini_ev    * bakim_minibüs_ev
    ) / 12

    # Yatırım tutarı
    yatirim = n_arac_ev_oto * fiyat_oto_ev + n_arac_ev_mini * fiyat_mini_ev

    # Taksit hesabı
    if odeme_plan == 1:
        taksit_sabit = yatirim / (yil * 12) if (yatirim > 0 and yil > 0) else 0
    else:
        if tufe > 0:
            carpan_t = sum((1 + tufe) ** t for t in range(yil))
            taksit_y1y = yatirim / carpan_t if carpan_t > 0 else 0
        else:
            taksit_y1y = yatirim / yil if yil > 0 else 0

    kayitlar = []
    for ay in range(1, yil * 12 + 1):
        yn = (ay - 1) // 12
        yc = (1 + tufe) ** yn
        yakıt  = (ayl_yakıt_d + ayl_yakıt_ev) * yc
        bakım  = ayl_bakım * yc
        taksit = (
            taksit_sabit if odeme_plan == 1
            else ((taksit_y1y / 12) * yc if yatirim > 0 else 0)
        )
        kayitlar.append({
            "ay": ay, "yil": yn + 1,
            "yakıt": yakıt, "bakım": bakım, "taksit": taksit,
            "toplam": yakıt + bakım + taksit,
        })
    return pd.DataFrame(kayitlar)


def run_analysis(w_emisyon, w_maliyet):
    """
    4 senaryoyu hesaplar:
      S0 – Mevcut durum (tüm araçlar dizel)
      S1 – 1/3 EV dönüşüm
      S2 – 2/3 EV dönüşüm
      S3 – 3/3 (tam) EV dönüşüm
    """
    # Araç sayılarını belirle
    n_oto_ev_s1  = oran_arac(n_otobüs_mevcut,  1/3)
    n_mini_ev_s1 = oran_arac(n_minibüs_mevcut, 1/3)
    n_oto_ev_s2  = oran_arac(n_otobüs_mevcut,  2/3)
    n_mini_ev_s2 = oran_arac(n_minibüs_mevcut, 2/3)
    n_oto_ev_s3  = n_otobüs_mevcut
    n_mini_ev_s3 = n_minibüs_mevcut

    configs = {
        "S0": (n_otobüs_mevcut, 0,           n_minibüs_mevcut, 0,            0,            0),
        "S1": (n_otobüs_mevcut - n_oto_ev_s1,  n_oto_ev_s1,
               n_minibüs_mevcut - n_mini_ev_s1, n_mini_ev_s1,
               n_oto_ev_s1,  n_mini_ev_s1),
        "S2": (n_otobüs_mevcut - n_oto_ev_s2,  n_oto_ev_s2,
               n_minibüs_mevcut - n_mini_ev_s2, n_mini_ev_s2,
               n_oto_ev_s2,  n_mini_ev_s2),
        "S3": (0, n_oto_ev_s3, 0, n_mini_ev_s3, n_oto_ev_s3, n_mini_ev_s3),
    }

    # Emisyon hesaplamaları
    emler = {}
    for kod, (a, b, c, d, _, __) in configs.items():
        emler[kod] = emisyon_hesapla(a, b, c, d, km_otobüs_yillik, km_minibüs_yillik)

    # Maliyet serileri
    dfs = {}
    for kod, (a, b, c, d, ev_oto, ev_mini) in configs.items():
        dfs[kod] = maliyet_serileri(
            a, b, c, d, ev_oto, ev_mini,
            fiyat_otobüs_ev, fiyat_minibüs_ev,
            tufe_orani, ANALIZ_YILI, odeme_plani
        )

    # ── Başabaş Noktası (Break-Even) ──
    # Tasarruf = S0 kümülatif maliyet – SenarYo X kümülatif maliyet
    # Yatırım  = toplam EV satın alma bedeli
    # Break-even: tasarruf ≥ yatırım olan ilk ay

    breakeven = {}
    for kod in ["S1", "S2", "S3"]:
        _, _, _, _, ev_oto, ev_mini = configs[kod]
        yatirim = ev_oto * fiyat_otobüs_ev + ev_mini * fiyat_minibüs_ev

        cumul_s0 = dfs["S0"]["toplam"].cumsum().values
        cumul_sx = dfs[kod]["toplam"].cumsum().values
        tasarruf = cumul_s0 - cumul_sx  # pozitif → EV daha ucuz

        # Break-even: EV toplam maliyeti (taksit dahil) = S0 maliyeti → tasarruf = 0 noktası
        # Yatırım taksit içine dahil edildiğinden "tasarruf ≥ 0" yeterli.
        be_ay = None
        for i, t in enumerate(tasarruf):
            if t >= 0:
                be_ay = i + 1  # 1-bazlı ay
                break
        breakeven[kod] = {
            "yatirim": yatirim,
            "tasarruf_serisi": tasarruf,
            "be_ay": be_ay,
            "be_yil": (be_ay / 12) if be_ay else None,
        }

    # AHP
    em_vals  = np.array([emler[k]["CO2e_ton"] for k in ["S0","S1","S2","S3"]])
    mal_vals = np.array([dfs[k]["toplam"].sum() for k in ["S0","S1","S2","S3"]])

    def norm_min(v):
        inv = 1.0 / (v + 1e-12)
        return inv / inv.sum()

    em_norm  = norm_min(em_vals)
    mal_norm = norm_min(mal_vals)
    ahp      = w_emisyon * em_norm + w_maliyet * mal_norm
    en_iyi   = ["S0","S1","S2","S3"][int(np.argmax(ahp))]

    return {
        "configs": configs,
        "emler": emler,
        "dfs": dfs,
        "breakeven": breakeven,
        "em_norm": em_norm,
        "mal_norm": mal_norm,
        "ahp": ahp,
        "en_iyi": en_iyi,
    }


